{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "target": "ES2022",
    "lib": ["ES2023"],
    "types": ["node"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "noEmit": true
  },
  "include": [
    "vite.config.ts",
    "eslint.config.js",
    "src/lib/sentinelVariants.ts",
    "src/server/**/*.ts",
    "src/types/**/*.ts",
    "api/**/*.ts"
  ]
}
