{
  "name": "earth-view-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop (Electron) wrapper for Earth View",
  "author": "Earth View",
  "main": "build/main.cjs",
  "scripts": {
    "build": "node build.mjs",
    "dev": "node build.mjs && electron .",
    "dist": "npm --prefix .. run build && node build.mjs && electron-builder"
  },
  "build": {
    "appId": "com.earthview.desktop",
    "productName": "Earth View",
    "directories": {
      "output": "release"
    },
    "files": [
      "build/**/*"
    ],
    "extraResources": [
      {
        "from": "../dist",
        "to": "frontend"
      }
    ],
    "win": {
      "target": "nsis",
      "artifactName": "Earth-View-Setup.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    }
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.0"
  }
}
